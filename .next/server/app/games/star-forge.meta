{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/games/layout,_N_T_/games/[slug]/layout,_N_T_/games/[slug]/page,_N_T_/games/star-forge"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/games/$d$slug/__PAGE__",
    "/games/$d$slug",
    "/games",
    "/_index",
    "/_head"
  ]
}