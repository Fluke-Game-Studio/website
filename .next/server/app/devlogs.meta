{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/devlogs/layout,_N_T_/devlogs/page,_N_T_/devlogs"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/devlogs/__PAGE__",
    "/devlogs",
    "/_index",
    "/_head"
  ]
}